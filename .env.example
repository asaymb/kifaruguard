POSTGRES_DB=kifaru_guard
POSTGRES_USER=kifaru
POSTGRES_PASSWORD=change_me
JWT_SECRET_KEY=change_this_secret
AUDIT_HMAC_SECRET=change_this_audit_secret
OPENAI_API_KEY=
RUNTIME_CONFIG_PATH=/app/config/runtime.yaml
PORT=8000
# Comma-separated browser origins — required for credentialed API calls (never use * with credentials).
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# production: set ENVIRONMENT=production and omit ALLOW_ADMIN_SEED (no default admin/admin123).
ENVIRONMENT=development
ALLOW_ADMIN_SEED=1
# Inbox "Process with agent" uses file_path under AGENT_FILE_ROOT — set AGENT_ALLOW_FILE_PATH=1 in Docker/production.
# AGENT_ALLOW_FILE_PATH=1
# AGENT_FILE_ROOT=/app/data/uploads
# MAX_AGENT_PDF_BYTES=10485760
