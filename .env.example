# === Copier vers .env à la racine (Docker / outils locaux) ===
# Ne jamais committer de secrets.

# --- Base de données (obligatoire si ENVIRONMENT=production) ---
DATABASE_URL=postgresql+psycopg2://kifaru:kifaru123@localhost:5432/kifaru_guard

# --- Sécurité (obligatoires au démarrage de l'API) ---
JWT_SECRET_KEY=change_this_secret
AUDIT_HMAC_SECRET=change_this_audit_secret

# --- Environnement d'exécution ---
# development : Ollama activé par défaut (Docker local avec service ollama).
# production  : Ollama désactivé par défaut → OpenAI puis repli sûr.
ENVIRONMENT=development

# --- CORS (origines du frontend, séparées par des virgules) ---
ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# --- LLM ---
# Clé OpenAI (recommandée en production sur Railway).
OPENAI_API_KEY=

# Forcer Ollama on/off (optionnel ; sinon dérivé de ENVIRONMENT).
# OLLAMA_ENABLED=1
# OLLAMA_ENABLED=0

# URL et modèle Ollama (dev / Docker : service "ollama")
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=tinyllama

# --- Config runtime (YAML agents / guardrails / llm) ---
RUNTIME_CONFIG_PATH=/app/config/runtime.yaml

# --- API ---
PORT=8000

# --- Postgres (docker-compose uniquement ; pas utilisé par FastAPI directement) ---
POSTGRES_DB=kifaru_guard
POSTGRES_USER=kifaru
POSTGRES_PASSWORD=change_me

# --- Admin seed (désactiver en vrai prod) ---
ALLOW_ADMIN_SEED=1

# --- Inbox / agents fichier ---
AGENT_FILE_ROOT=/app/data/uploads
AGENT_ALLOW_FILE_PATH=1
MAX_AGENT_PDF_BYTES=10485760

# --- Fichiers sanctions (chemins dans le conteneur ou absolus locaux) ---
SANCTIONS_MINES_CSV=/app/data/sanctions_mines.csv
SANCTIONS_BANK_CSV=/app/data/sanctions_politiques.csv

# --- Frontend (build Vite ; laisser vide = même origine / proxy Nginx) ---
# VITE_API_BASE_URL=
